SELECT * FROM ACCIDENT_DB.PUBLIC.ACCIDENT;
SELECT * FROM ACCIDENT_DB.PUBLIC.VEHICLE;


--How many accidents have occurred in urban areas versus rural areas?
SELECT Area,
	COUNT(AccidentIndex) AS Total_Accident
FROM ACCIDENT_DB.PUBLIC.ACCIDENT
GROUP BY Area;

--Which day of the week has the highest number of accidents?
SELECT 
	Day,
	COUNT(AccidentIndex) AS Total_Accident
FROM 
	ACCIDENT_DB.PUBLIC.ACCIDENT
GROUP BY 
	Day
ORDER BY 
	Total_Accident DESC;

--What is the average age of vehicles involved in accidents based on their type?
SELECT 
	VehicleType, 
	COUNT(AccidentIndex) AS Total_Accident, 
	AVG(AgeVehicle) AS Average_Age
FROM 
	ACCIDENT_DB.PUBLIC.VEHICLE
WHERE 
	AgeVehicle IS NOT NULL
GROUP BY 
	VehicleType
ORDER BY 
	Total_Accident DESC;

--Can we identify any trends in accidents based on the age of vehicles involved?
SELECT 
	AgeGroup,
	COUNT(AccidentIndex) AS Total_Accident,
	AVG(AgeVehicle) AS Average_Year
FROM (
	SELECT
		AccidentIndex,
		AgeVehicle,
		CASE
			WHEN AgeVehicle BETWEEN 0 AND 5 THEN 'New'
			WHEN AgeVehicle BETWEEN 6 AND 10 THEN 'Regular'
			ELSE 'Old'
		END AS AgeGroup
	FROM ACCIDENT_DB.PUBLIC.VEHICLE
) SubQuery
GROUP BY 
	AgeGroup;

--Are there any specific weather conditions that contribute to severe accidents?
SET Severity_Filter = 'Fatal'; --Serious, Fatal, Slight

SELECT 
	WeatherConditions,
	COUNT(Severity) AS Total_Accident
FROM 
	ACCIDENT_DB.PUBLIC.ACCIDENT
WHERE 
	Severity = $Severity_Filter
GROUP BY 
	WeatherConditions
ORDER BY 
	Total_Accident DESC;

--Do accidents often involve impacts on the left-hand side of vehicles?
SELECT 
	LeftHand, 
	COUNT(AccidentIndex) AS Total_Accident
FROM 
	ACCIDENT_DB.PUBLIC.VEHICLE
WHERE
	LeftHand IS NOT NULL
GROUP BY 
	LeftHand;

--Are there any relationships between journey purposes and the severity of accidents?
SELECT 
	V.JourneyPurpose,
	COUNT(CASE WHEN A.Severity = 'Slight' THEN 1 END) AS Slight,
	COUNT(CASE WHEN A.Severity = 'Serious' THEN 1 END) AS Serious,
	COUNT(CASE WHEN A.Severity = 'Fatal' THEN 1 END) AS Fatal,
	COUNT(*) AS Total_Accident,
	ROUND(COUNT(CASE WHEN A.Severity IN ('Serious', 'Fatal') THEN 1 END) * 100.0 / COUNT(*), 2) AS Severe_Pct
FROM 
	ACCIDENT_DB.PUBLIC.ACCIDENT A
JOIN 
	ACCIDENT_DB.PUBLIC.VEHICLE V ON A.AccidentIndex = V.AccidentIndex
GROUP BY 
	V.JourneyPurpose
ORDER BY 
	Severe_Pct DESC;

--Calculate the average age of vehicles involved in accidents, considering Day light and point of impact.

--SET Impact_Filter = 'Offside';
--SET Light_Filter = 'Darkness';

SELECT 
	A.LightConditions, 
	V.PointImpact, 
	AVG(V.AgeVehicle) AS Average_Vehicle_Year
FROM 
	ACCIDENT_DB.PUBLIC.ACCIDENT A
JOIN 
	ACCIDENT_DB.PUBLIC.VEHICLE V ON A.AccidentIndex = V.AccidentIndex
WHERE 
	V.PointImpact NOT IN ('Did not impact', 'Data missing or out of range')
GROUP BY 
	V.PointImpact, A.LightConditions;
